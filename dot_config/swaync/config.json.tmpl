{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",

  "control-center-margin-top": {{ .gaps }},
  "control-center-margin-bottom": {{ .gaps }},
  "control-center-margin-left": {{ .gaps }},
  "control-center-margin-right": {{ .gaps }},

  "layer-shell": true,
  "cssPriority": "application",

  "control-center-width": 380,
  "control-center-height": 600,
  "notification-window-width": 380,

  "notification-icons": true,
  "notification-icon-size": 32,

  "timeout": 5,
  "ignoreTimeout": false,

  "keyboard-shortcuts": true,

  "actions": {
    "open": "xdg-open",
    "default": "xdg-open"
  },

  "blacklist": {
    "applications": []
  },

  "widgets": ["notifications", "title"],

  "widget-config": {
    "title": {
      "text": "",
      "clear-all-button": true,
      "button-text": "Clear All"
    }
  }
}
